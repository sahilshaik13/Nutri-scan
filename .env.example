# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API Configuration (multiple keys for failover/load balancing)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_primary
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3
GEMINI_API_KEY_4=your_gemini_api_key_4

# Frontend & Backend Architecture (Separate Services)
# Frontend: Next.js on port 3000 (development) or Vercel (production)
# Backend: FastAPI
# 
# Development:
#   API URL: http://localhost:8000 (local FastAPI backend)
#   Terminal 1: npm run dev              (frontend on http://localhost:3000)
#   Terminal 2: cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload
# 
# Production:
#   API URL: https://nutri-scan-fvyo.onrender.com (hosted backend on Render)
#   Frontend deployed to Vercel, automatically uses production backend URL

# Local development - backend on port 8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production backend URL (used when deployed to Vercel)
# This can be overridden in Vercel project settings
NEXT_PUBLIC_PRODUCTION_API_URL=https://nutri-scan-fvyo.onrender.com

