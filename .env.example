# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API Configuration
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
# OR (alternative env var name)
GEMINI_API_KEY=your_gemini_api_key

# Frontend & Backend Connection
# In development: http://localhost:3000 (same as frontend)
# In production: https://your-domain.com (same as frontend)
# API routes are automatically served by the same service, no need to set this
# NEXT_PUBLIC_API_URL is optional and defaults to the current domain

# Optional: For external backend services (if not using multi-service architecture)
# BACKEND_URL=http://localhost:8000

