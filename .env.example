# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API Configuration (multiple keys for failover/load balancing)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_primary
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3
GEMINI_API_KEY_4=your_gemini_api_key_4

# Frontend & Backend Architecture (Unified on Port 3000)
# Both frontend and backend run on the same port (3000)
# API routes (/api/*) are handled by Next.js route handlers
# No external FastAPI backend service needed
# 
# Development: npm run dev (starts on http://localhost:3000)
# Production: Vercel deploys as single Next.js service on port 3000
# All API calls use relative paths: /api/analyze-image, /api/calculate-nutrition, /api/guest/session, etc.

